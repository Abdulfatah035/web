!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shield & Script Solutions</title>
  <link rel="stylesheet" href="lab8_style.css">
</head>
<body>
  <header>
    <h1>Shield & Script Solutions</h1>
    <p>Reliable web security and development services.</p>
  </header>

  <section class="status-banner">
    <h2>Security Status</h2>
    <p>System Protected and Monitoring Active</p>
  </section>

  <section class="services">
    <div class="service-box">
      <h3>Website Security</h3>
      <p>We protect websites from common online threats.</p>
    </div>

    <div class="service-box">
      <h3>Frontend Development</h3>
      <p>We build clean and responsive user interfaces.</p>
    </div>

    <div class="service-box">
      <h3>Performance Support</h3>
      <p>We improve website speed and overall performance.</p>
    </div>
  </section>

  <section class="repo-link">
    <h2>Git Repository</h2>
    <p>
      Webpage Link:
      <a href="https://github.com/example/shield-script-solutions">
        https://github.com/example/shield-script-solutions
      </a>
    </p>
  </section>
</body>
</html>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  background-color: #f4f4f4;
  color: #222222;
}

header {
  background-color: #1f3c88;
  color: white;
  text-align: center;
  padding: 25px;
}

.status-banner {
  background-color: #dff6dd;
  color: #14532d;
  text-align: center;
  padding: 15px;
  margin: 20px;
  border: 2px solid #22c55e;
  animation-name: pulseBanner;
  animation-duration: 2s;
  animation-iteration-count: infinite;
}

.services {
  display: flex;
  justify-content: space-around;
  gap: 20px;
  margin: 20px;
  flex-wrap: wrap;
}

.service-box {
  background-color: white;
  width: 250px;
  padding: 20px;
  border: 1px solid #cccccc;
  text-align: center;
  transition: transform 0.4s ease, background-color 0.4s ease;
}

.service-box:hover {
  background-color: #e0ecff;
  transform: scale(1.05) translateY(-10px) rotate(1deg);
}

.repo-link {
  margin: 20px;
  padding: 20px;
}

.repo-link a {
  color: #1f3c88;
}

@keyframes pulseBanner {
  0% {
    opacity: 1;
    transform: scale(1);
  }

  50% {
    opacity: 0.7;
    transform: scale(1.03);
  }

  100% {
    opacity: 1;
    transform: scale(1);
  }
}
